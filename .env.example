# ============================================
# AdCure CRM - Environment Variables
# ============================================
# Copy this file to .env and fill in the values
# NEVER commit .env to git (it's in .gitignore)
# ============================================

# ------------------
# SUPABASE
# ------------------
# Get from: https://app.supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxx

# Service role key (NEVER expose to frontend!)
# Only use in server-side functions
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxx

# ------------------
# SUPPLIER API
# ------------------
# Get from supplier (your main ad account provider)
VITE_SUPPLIER_API_URL=https://api.supplier.com
SUPPLIER_AUTH_TOKEN=your-supplier-auth-token-here

# ------------------
# MONEYBIRD (invoicing)
# ------------------
# Get from: Moneybird → Settings → API Tokens
MONEYBIRD_API_KEY=your-moneybird-api-key
MONEYBIRD_ADMINISTRATION_ID=123456789
MONEYBIRD_WEBHOOK_SECRET=generate-random-secret

# ------------------
# RESEND (emails)
# ------------------
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@adcure.agency
RESEND_FROM_NAME=AdCure Agency

# ------------------
# ANTHROPIC (AI payment validation)
# ------------------
# Get from: https://console.anthropic.com/
# Use project-specific key for cost tracking
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ------------------
# REVOLUT (optional - Phase 5)
# ------------------
# Get from: Revolut Business → Settings → Developers
REVOLUT_API_KEY=your-revolut-api-key
REVOLUT_ACCOUNT_ID=your-revolut-account-id
REVOLUT_WEBHOOK_SECRET=generate-random-secret

# ------------------
# BUSINESS CONFIG
# ------------------
# Revolut bank account (for client transfers)
REVOLUT_IBAN=NL14REV0766119691
REVOLUT_BIC=REV0NL22
REVOLUT_BENEFICIARY=Adcure Agency

# Fee configuration
DEFAULT_SUPPLIER_FEE=2
DEFAULT_AGENCY_FEE=5
VAT_RATE=21

# ------------------
# SAFETY LIMITS
# ------------------
# Maximum top-up per transaction (in EUR)
MAX_TOPUP_AMOUNT=10000

# Maximum daily volume per client
MAX_DAILY_VOLUME_CLIENT=20000

# Maximum daily volume total
MAX_DAILY_VOLUME_TOTAL=50000

# ------------------
# APP CONFIG
# ------------------
# Environment: development, staging, production
NODE_ENV=development

# App URL (for emails, webhooks, etc.)
VITE_APP_URL=http://localhost:5173

# Session timeout (in hours)
SESSION_TIMEOUT_HOURS=24

# ------------------
# FEATURE FLAGS
# ------------------
# Enable AI payment validation
FEATURE_AI_VALIDATION=false

# Enable Revolut automation
FEATURE_REVOLUT_AUTOMATION=false

# Enable WhatsApp notifications
FEATURE_WHATSAPP=false

# ------------------
# DEVELOPMENT / TESTING
# ------------------
# Mock external APIs in dev mode
DEV_MOCK_SUPPLIER_API=true
DEV_MOCK_MONEYBIRD=true
DEV_MOCK_EMAILS=true

# Test mode safety (max €10 transactions)
DEV_MAX_TEST_AMOUNT=10
